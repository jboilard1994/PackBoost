{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Debug Tests (Pytest)",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "purpose": [
                "debug-test"
            ],
            "cwd": "${workspaceFolder}",
            "args": [
                "-q"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}
